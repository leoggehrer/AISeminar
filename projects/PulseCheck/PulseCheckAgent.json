                "value": "*"
              }
            ]
          }
        }
      },
      "id": "0daa8eab-89d3-40fa-a35e-af9b46f38f7e",
      "name": "Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1136,
        -144
      ]
    }
  ],
