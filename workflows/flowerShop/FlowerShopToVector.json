      "id": "07400a24-ffa9-43b9-b532-1a8219fd2d07",
      "name": "ExtractFromFile"
    },
    {
      "parameters": {
        "jsCode": "// Alle Items vom vorherigen Node holen\nconst items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n  const block = item.json.block;\n\n  // 1) Titel parsen: \"**Nr. 1 – Sonniger Gruß** (Niedrigpreis)\"\n  // Format: **Nr. X – Name** (Preiskategorie)\n  const titleMatch = block.match(/^\\*\\*Nr\\.\\s*(\\d+)\\s*–\\s*(.+?)\\*\\*\\s*(?:\\((\\w+)\\))?$/m);\n  if (!titleMatch) {\n    // Kein gültiger Konfigurationsblock -> überspringen\n    continue;\n  }\n\n  const id = titleMatch[1];\n  const name = titleMatch[2].trim();\n  const priceCategory = titleMatch[3] ? titleMatch[3].trim() : null; // Niedrigpreis, Mittelpreis, Hochpreis\n\n  // Zeilenweise arbeiten\n  const lines = block.split('\\n');\n\n  // Hilfsfunktion: Finde den Index einer Zeile mit bestimmtem Prefix\n  const findLineIndex = (prefix) =>\n    lines.findIndex(l => l.trim().startsWith(prefix));\n\n  // Hilfsfunktion: Hole die nächste nicht-leere Zeile nach einem Index\n  const getNextNonEmptyLine = (startIndex) => {\n    for (let i = startIndex + 1; i < lines.length; i++) {\n      const trimmed = lines[i].trim();\n      if (trimmed.length > 0 && !trimmed.startsWith('**')) {\n        return trimmed;\n      }\n    }\n    return '';\n  };\n\n  // 2) Artikel parsen: Zeilen die mit \"* B\" beginnen\n  // Neues Format: \"* B1018 – Sonnenblume – Menge: 3× – Preis: 7,53 €\"\n  const articles = [];\n  const articleLines = lines.filter(l => l.trim().startsWith('* B'));\n  \n  for (const line of articleLines) {\n    const articleMatch = line.match(/\\*\\s*(B\\d+)\\s*–\\s*(.+?)\\s*–\\s*Menge:\\s*(\\d+)×\\s*–\\s*Preis:\\s*([\\d,]+)\\s*€/);\n    if (articleMatch) {\n      articles.push({\n        articleId: articleMatch[1],\n        productName: articleMatch[2].trim(),\n        quantity: parseInt(articleMatch[3], 10),\n        unitPrice: parseFloat(articleMatch[4].replace(',', '.'))\n      });\n    }\n  }\n\n  // 3) Gesamtpreis parsen\n  const priceLineIndex = findLineIndex('**Gesamtpreis:**');\n  let price = null;\n  if (priceLineIndex !== -1) {\n    const priceLine = lines[priceLineIndex].trim();\n    const priceMatch = priceLine.match(/\\*\\*Gesamtpreis:\\*\\*\\s*([\\d,]+)\\s*€/);\n    if (priceMatch) {\n      price = parseFloat(priceMatch[1].replace(',', '.'));\n    }\n  }\n\n  // 4) Tags parsen (auf der nächsten Zeile nach **Tags:**)\n  const tagsLineIndex = findLineIndex('**Tags:**');\n  let tags = [];\n  if (tagsLineIndex !== -1) {\n    const tagsLine = getNextNonEmptyLine(tagsLineIndex);\n    tags = tagsLine\n      .split('#')\n      .map(t => t.trim())\n      .filter(t => t.length > 0);\n  }\n\n  // 5) Anlass parsen (auf der nächsten Zeile nach **Anlass:**)\n  const occasionLineIndex = findLineIndex('**Anlass:**');\n  let occasions = [];\n  if (occasionLineIndex !== -1) {\n    const occasionLine = getNextNonEmptyLine(occasionLineIndex);\n    occasions = occasionLine\n      .split(',')\n      .map(o => o.trim())\n      .filter(o => o.length > 0);\n  }\n\n  // 6) Beschreibung parsen (auf der nächsten Zeile nach **Beschreibung:**)\n  const descLineIndex = findLineIndex('**Beschreibung:**');\n  let description = '';\n  if (descLineIndex !== -1) {\n    description = getNextNonEmptyLine(descLineIndex);\n  }\n\n  // Artikel-IDs für das Embedding extrahieren\n  const articleIds = articles.map(a => a.articleId);\n  const articleSummary = articles\n    .map(a => `${a.articleId} ${a.productName} (${a.quantity}×)`)\n    .join(', ');\n\n  // Text für Embedding\n  const textForEmbedding = `\nName: ${name}.\nPreiskategorie: ${priceCategory || 'Nicht angegeben'}.\nBeschreibung: ${description}.\nTags: ${tags.join(', ')}.\nAnlass: ${occasions.join(', ')}.\nArtikel: ${articleSummary}.\nPreis: ${price} Euro.\n`.trim();\n\n  // Sauberes Item im erwarteten Format\n  output.push({\n    json: {\n      configId: id,\n      name,\n      priceCategory,   // Niedrigpreis, Mittelpreis, Hochpreis\n      description,\n      price,\n      articles,        // Array mit {articleId, productName, quantity, unitPrice}\n      articleIds,      // Nur die IDs als Array\n      tags,\n      occasions,\n      textForEmbedding,\n    },\n  });\n}\n\n// Alle erzeugten Items zurückgeben\nreturn output;\n"
      },
