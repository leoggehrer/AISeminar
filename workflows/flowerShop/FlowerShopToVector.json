        "jsCode": "const fullText = $json.text;\n\nconst blocks = fullText\n  .split('---')\n  .map(b => b.trim())\n  .filter(b => b.length > 0);\n\nreturn blocks.map(block => ({ json: { block } }));\n"
      },
